# App
APP_PORT=8080
APP_ENV=development
# LOG_LEVEL: debug | info | warn | error (overrides env-based default)
LOG_LEVEL=debug

# PostgreSQL (LMS app)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_password
POSTGRES_DB=lms_db
POSTGRES_SSLMODE=disable

# Keycloak admin console (master realm)
KC_PORT=8081
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin

# Keycloak's own PostgreSQL
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak_password
KC_DB_NAME=keycloak_db

# How the Go service talks to Keycloak.
# KEYCLOAK_URL is the address the backend USES to reach Keycloak (must be
# reachable): localhost:8081 on the host, http://keycloak:8080 inside compose.
# KEYCLOAK_ISSUER_URL is the URL baked into token "iss" — leave empty to reuse
# KEYCLOAK_URL (host run); set to http://localhost:8081 when the app runs in
# docker so it validates the external issuer. Compose sets this automatically.
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_ISSUER_URL=
KEYCLOAK_REALM=lms
KEYCLOAK_CLIENT_ID=lms-backend
# Must match clients[].secret in keycloak/import/realm-export.json
KEYCLOAK_CLIENT_SECRET=lms-backend-secret
# Master-realm admin used by the backend to create/update users (admin API).
# Defaults match KC_ADMIN / KC_ADMIN_PASSWORD above.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# MinIO (S3-compatible object store for file attachments).
# MINIO_ROOT_USER/PASSWORD are the MinIO admin credentials (also used by the
# backend as access/secret key). API port 9000, web console 9001.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=lms-attachments
# MINIO_ENDPOINT is what the backend USES to reach MinIO (host:port, no scheme):
# localhost:9000 on the host, minio:9000 inside compose (set automatically).
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
