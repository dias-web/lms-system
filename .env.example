# App
APP_PORT=8080
APP_ENV=development
# LOG_LEVEL: debug | info | warn | error (overrides env-based default)
LOG_LEVEL=debug

# PostgreSQL (LMS app)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_password
POSTGRES_DB=lms_db
POSTGRES_SSLMODE=disable

# Keycloak admin console (master realm)
KC_PORT=8081
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin

# Keycloak's own PostgreSQL
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak_password
KC_DB_NAME=keycloak_db

# How the Go service talks to Keycloak (token validation + admin API).
# URL must match the token issuer: localhost:8081 when app runs on the host,
# http://keycloak:8080 when the app runs inside docker-compose.
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=lms
KEYCLOAK_CLIENT_ID=lms-backend
# Must match clients[].secret in keycloak/import/realm-export.json
KEYCLOAK_CLIENT_SECRET=lms-backend-secret
# Master-realm admin used by the backend to create/update users (admin API).
# Defaults match KC_ADMIN / KC_ADMIN_PASSWORD above.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
